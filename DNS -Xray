{
  "hosts": {
    "dns.google": "8.8.8.8",
    "proxy.example.com": "127.0.0.1"
  },

  // ---------- 2. DNS 服务器列表 ----------
  // 按顺序匹配，匹配成功即返回；若返回结果不满足 expectIPs，则继续尝试下一个服务器
  "servers": [
    // 2.1 国外域名 → Google DoH（专门用于 geosite:google、geosite:category-foreign 等）
    {
      "address": "https://dns.google/dns-query",
      "domains": [
        "geosite:google",
        "geosite:geolocation-!cn"
      ],
      // 只在匹配到上述 domains 时使用，不参与全局 fallback
      "skipFallback": true
    },

    // 2.2 国内域名 → 腾讯 DoH（国内常用 DNS，返回的 IP 必须是中国 IP）
    {
      "address": "https://doh.pub/dns-query",
      "domains": [
        "geosite:cn"
      ],
      // 要求返回的 IP 属于中国 IP 段，否则视为不合格，继续后面的 fallback
      "expectedIPs": [
        "geoip:cn"
      ],
      "skipFallback": true
    },

    // 2.3 兜底服务器 → Google DoH（所有未匹配到前两条规则的请求走这里）
    "https://dns.google/dns-query"
  ]
}
