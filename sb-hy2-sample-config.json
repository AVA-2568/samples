{
  "inbounds": [
    {
      "type": "hysteria2",
      "listen": "::",
      "listen_port": 443,
      "up_mbps": 800,
      "down_mbps": 700,
      "users": [
        {
          "name": "АЁАЁАЁАЁАЁАЁ",
          "password": "АЁАЁАЁАЁАЁАЁ"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "АЁАЁАЁАЁАЁАЁ",
        "alpn": "h3",
        "certificate": [
          "-----BEGIN CERTIFICATE-----",
          "АЁАЁАЁАЁАЁАЁ",
          "АЁАЁАЁАЁАЁАЁ",
          "-----END CERTIFICATE-----",
          "-----BEGIN CERTIFICATE-----",
          "АЁАЁАЁАЁАЁАЁ",
          "АЁАЁАЁАЁАЁАЁ",
          "-----END CERTIFICATE-----"
        ],
        "certificate_path": "/etc/АЁАЁАЁАЁАЁАЁ/tls/АЁАЁАЁАЁАЁАЁ",
        "key": [
          "-----BEGIN EC PRIVATE KEY-----",
          "АЁАЁАЁАЁАЁАЁ",
          "АЁАЁАЁАЁАЁАЁ",
          "-----END EC PRIVATE KEY-----"
        ],
        "key_path": "/etc/АЁАЁАЁАЁАЁАЁ/tls/АЁАЁАЁАЁАЁАЁ"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out",
    }
  ],
  "route": {
    "rules": [
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": "geoip-ir",
        "rule_set_ipcidr_match_source": true,
        "action": "reject"
      },
      {
        "rule_set": "geoip-in",
        "rule_set_ipcidr_match_source": true,
        "action": "reject"
      },
      {
        "rule_set": "geosite-cn",
        "action": "reject"
      },
      {
        "rule_set": "geosite-speedtest",
        "action": "reject"
      },
      {
        "rule_set": "geosite-pt",
        "action": "reject"
      },
      {
        "rule_set": "geosite-ads",
        "action": "reject"
      }
    ],
    "rule_set": [
      {
        "tag": "geoip-ir",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-ir.srs"
      },
      {
        "tag": "geoip-in",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-in.srs"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-cn.srs"
      },
      {
        "tag": "geosite-speedtest",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-category-speedtest.srs"
      },
      {
        "tag": "geosite-pt",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-category-pt.srs"
      },
      {
        "tag": "geosite-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-category-ads-all.srs"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  }
}