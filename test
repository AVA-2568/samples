{
  "log": {
    "loglevel": "warning",
  },
  "dns": {
    "servers": [
      {
        "address": "https+local://8.8.8.8/dns-query",
        "skipFallback": true
      }
    ],
    "queryStrategy": "UseIP"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "port": 25365,
      "protocol": "socks",
      "settings": {
        "auth": "password",
        "accounts": [
          {
            "user": "REPLACE_WITH_USERNAME",
            "pass": "REPLACE_WITH_STRONG_PASSWORD"
          }
        ],
        "udp": false,
        "ip": "127.0.0.1"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          "socks-in"
        ],
        "network": "udp",
        "outboundTag": "block"
      },
      {
        "type": "field",
        "ip": [
          "geoip:cn",
          "geoip:ir",
          "geoip:in",
          "geoip:ru"
        ],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "network": "tcp"
      }
    ]
  }
}
