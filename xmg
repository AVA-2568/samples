show_links_for_user() {
  ensure_users_file
  gen_reality_keys

  local name
  read -rp "用户名称，留空显示全部: " name

  jq -r --arg name "$name" '
    .users[]
    | select(.enabled == true)
    | select($name == "" or .name == $name)
    | [.name, .uuid, .reality, .ws, .xhttp_tls]
    | @tsv
  ' "$USERS_FILE" | while IFS=$'\t' read -r uname uuid reality ws xhttp_tls; do
    echo
    blue "用户：$uname"
    if [[ "$reality" == "true" ]]; then
      echo "Reality-XHTTP:"
      link_reality "$uname" "$uuid"
    fi
    if [[ -n "$DOMAIN" && "$ws" == "true" ]]; then
      echo "WS-TLS:"
      link_ws_tls "$uname" "$uuid"
    fi
    if [[ -n "$DOMAIN" && "$xhttp_tls" == "true" ]]; then
      echo "XHTTP-TLS:"
      link_xhttp_tls "$uname" "$uuid"
    fi
  done
}

