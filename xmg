  green "更新完成。"
}

show_status() {
  echo "XMG 版本：$XMG_VERSION"
  echo "域名：${DOMAIN:-未设置}"
  echo "Reality 端口：$REALITY_PORT"
  echo "WS 路径：$WS_PATH"
  echo "XHTTP TLS 路径：$XHTTP_TLS_PATH"
  echo "Reality XHTTP 路径：$REALITY_XHTTP_PATH"
  echo "订阅 Token：$SUB_TOKEN"
  echo

  systemctl status xray --no-pager -l || true
  echo
  systemctl status caddy --no-pager -l || true
  echo
  ss -lntp | grep -E "(:80|:443|:${REALITY_PORT}|:${XRAY_LOCAL_WS_PORT}|:${XRAY_LOCAL_XHTTP_PORT})\b" || true
}

view_logs() {
  echo "1. Xray 日志"
  echo "2. Caddy 日志"
  read -rp "请选择: " choice

  case "$choice" in
    1) journalctl -u xray -e --no-pager ;;
    2) journalctl -u caddy -e --no-pager ;;
    *) red "无效选择" ;;
  esac
}

restart_services() {
  xray test -config "$XRAY_CONFIG"
  systemctl restart xray
  systemctl reload caddy || systemctl restart caddy
  green "服务已重启。"
}

backup_config() {
  local backup="/root/xmg-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
  tar -czf "$backup" "$BASE_DIR" "$XRAY_CONFIG" "$CADDYFILE" "$WEB_BASE" 2>/dev/null || true
  chmod 0600 "$backup"
  green "备份完成：$backup"
}

uninstall_xmg() {
  yellow "此操作会卸载 XMG 配置，可选择是否卸载 Xray/Caddy。"
  read -rp "确认继续？输入 YES: " confirm
  [[ "$confirm" == "YES" ]] || return 0

  systemctl stop xray caddy 2>/dev/null || true

  read -rp "是否删除 Xray-core？[y/N]: " remove_xray
  if [[ "${remove_xray,,}" == "y" ]]; then
    bash <(curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh) remove --purge || true
  fi

  read -rp "是否删除 Caddy？[y/N]: " remove_caddy
  if [[ "${remove_caddy,,}" == "y" ]]; then
    apt-get purge -y caddy || true
  fi

  rm -rf "$BASE_DIR" "$WEB_BASE"
  rm -f /usr/local/bin/xmg

  green "卸载完成。"
}

security_check() {
  echo "基础安全检查："
  echo "- 系统：$(. /etc/os-release && echo "${PRETTY_NAME:-unknown}")"
  echo "- Xray：$(command -v xray >/dev/null && xray version | head -n1 || echo 未安装)"
  echo "- Caddy：$(command -v caddy >/dev/null && caddy version || echo 未安装)"
  echo "- state 权限：$(stat -c '%a %n' "$STATE_FILE" 2>/dev/null || echo 未生成)"
  echo "- users 权限：$(stat -c '%a %n' "$USERS_FILE" 2>/dev/null || echo 未生成)"
  echo "- 防火墙：$(ufw status 2>/dev/null | head -n1 || echo 未安装)"
  echo "- 开放端口："
  ss -lntp | awk 'NR==1 || /:80|:443|:8443|:10001|:10002/'
}

