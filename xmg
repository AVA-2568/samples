link_reality() {
  local name="$1"
  local uuid="$2"
  local host path_enc tag
  host="$(public_host_for_reality)"
  path_enc="$(urlencode_path "$REALITY_XHTTP_PATH")"
  tag="$(urlencode_path "xmg-reality-$name")"

  echo "vless://${uuid}@${host}:${REALITY_PORT}?encryption=none&type=xhttp&security=reality&sni=${REALITY_SNI}&fp=chrome&pbk=${REALITY_PUBLIC_KEY}&sid=${REALITY_SHORT_ID}&path=${path_enc}&mode=auto#${tag}"
}

link_ws_tls() {
  local name="$1"
  local uuid="$2"
  local path_enc tag
  path_enc="$(urlencode_path "$WS_PATH")"
  tag="$(urlencode_path "xmg-ws-$name")"

  echo "vless://${uuid}@${DOMAIN}:443?encryption=none&type=ws&security=tls&sni=${DOMAIN}&host=${DOMAIN}&path=${path_enc}#${tag}"
}

link_xhttp_tls() {
  local name="$1"
  local uuid="$2"
  local path_enc tag
  path_enc="$(urlencode_path "$XHTTP_TLS_PATH")"
  tag="$(urlencode_path "xmg-xhttp-$name")"

  echo "vless://${uuid}@${DOMAIN}:443?encryption=none&type=xhttp&security=tls&sni=${DOMAIN}&host=${DOMAIN}&path=${path_enc}&mode=auto#${tag}"
}

build_subscriptions() {
  ensure_users_file
  gen_reality_keys || true

  mkdir -p "$SUB_DIR"
  rm -f "$SUB_DIR"/*.txt "$SUB_DIR"/*.b64

  local tmp_all tmp_reality tmp_ws tmp_xhttp
  tmp_all="$(mktemp)"
  tmp_reality="$(mktemp)"
  tmp_ws="$(mktemp)"
  tmp_xhttp="$(mktemp)"

  while IFS=$'\t' read -r name uuid reality ws xhttp_tls; do
    if [[ "$reality" == "true" ]]; then
      link_reality "$name" "$uuid" | tee -a "$tmp_reality" >> "$tmp_all"
    fi

    if [[ -n "$DOMAIN" && "$ws" == "true" ]]; then
      link_ws_tls "$name" "$uuid" | tee -a "$tmp_ws" >> "$tmp_all"
    fi

    if [[ -n "$DOMAIN" && "$xhttp_tls" == "true" ]]; then
      link_xhttp_tls "$name" "$uuid" | tee -a "$tmp_xhttp" >> "$tmp_all"
    fi
  done < <(jq -r '.users[] | select(.enabled == true) | [.name, .uuid, .reality, .ws, .xhttp_tls] | @tsv' "$USERS_FILE")

  base64 -w 0 "$tmp_all" > "$SUB_DIR/all.b64"
  base64 -w 0 "$tmp_reality" > "$SUB_DIR/reality.b64"
  base64 -w 0 "$tmp_ws" > "$SUB_DIR/ws.b64"
  base64 -w 0 "$tmp_xhttp" > "$SUB_DIR/xhttp-tls.b64"

  rm -f "$tmp_all" "$tmp_reality" "$tmp_ws" "$tmp_xhttp"
  chmod 0640 "$SUB_DIR"/*.b64

  write_panel_html

  green "Base64 订阅已生成："
  if [[ -n "$DOMAIN" ]]; then
    echo "面板：https://$DOMAIN/$SUB_TOKEN/"
    echo "All：https://$DOMAIN/$SUB_TOKEN/sub/all.b64"
    echo "Reality：https://$DOMAIN/$SUB_TOKEN/sub/reality.b64"
    echo "WS-TLS：https://$DOMAIN/$SUB_TOKEN/sub/ws.b64"
    echo "XHTTP-TLS：https://$DOMAIN/$SUB_TOKEN/sub/xhttp-tls.b64"
    echo "面板账号：$PANEL_USER"
    echo "面板密码：$PANEL_PASS"
  else
    yellow "未设置域名，HTTPS 订阅链接暂不可用。"
  fi
}

