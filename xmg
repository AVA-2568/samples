main_loop() {
  while true; do
    menu
    read -rp "请选择: " choice

    case "$choice" in
      1) install_all; pause ;;
      2) set_basic_info; pause ;;
      3) install_xray; pause ;;
      4) install_caddy; pause ;;
      5) write_xray_config; pause ;;
      6) write_caddyfile; pause ;;
      7) add_user; pause ;;
      8) delete_user; pause ;;
      9) toggle_user; pause ;;
      10) list_users; pause ;;
      11) change_ports_paths; pause ;;
      12) build_subscriptions; pause ;;
      13) show_links_for_user; pause ;;
      14) pull_site_from_github; write_caddyfile; pause ;;
      15) show_status; pause ;;
      16) view_logs; pause ;;
      17) restart_services; pause ;;
      18) setup_firewall; pause ;;
      19) backup_config; pause ;;
      20) security_check; pause ;;
      21) update_all; pause ;;
      99) uninstall_xmg; exit 0 ;;
      0) exit 0 ;;
      *) red "无效选项"; pause ;;
    esac
  done
}

main() {
  need_root
  detect_os
  init_dirs
  load_state
  save_state
  ensure_users_file

  if [[ "${1:-}" == "install" ]]; then
    install_all
    exit 0
  fi

  if [[ "${1:-}" == "status" ]]; then
    show_status
    exit 0
  fi

  if [[ "${1:-}" == "links" ]]; then
    show_links_for_user
    exit 0
  fi

  if [[ "${1:-}" == "sub" ]]; then
    build_subscriptions
    exit 0
  fi

  main_loop
}

main "$@"
