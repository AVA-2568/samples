cert_status() {
  require_domain || return 1

  local cert
  cert="$(find "$CADDY_CERT_DIR" -type f -name "${DOMAIN}.crt" 2>/dev/null | head -n1 || true)"

  if [[ -z "$cert" ]]; then
    yellow "未找到 Caddy 证书，可能尚未成功签发：$DOMAIN"
    return 1
  fi

  echo "证书文件：$cert"
  openssl x509 -in "$cert" -noout -subject -issuer -dates

  local end_epoch now_epoch left_days
  end_epoch="$(openssl x509 -in "$cert" -noout -enddate | cut -d= -f2 | xargs -I{} date -d "{}" +%s)"
  now_epoch="$(date +%s)"
  left_days="$(( (end_epoch - now_epoch) / 86400 ))"

  if (( left_days < 15 )); then
    red "证书剩余天数较少：${left_days} 天"
    return 1
  fi

  green "证书状态正常，剩余约 ${left_days} 天。"
}

doctor() {
  local failed=0

  echo "== XMG Doctor =="

  echo
  echo "[1] Xray 配置检查"
  if [[ -f "$XRAY_CONFIG" ]] && command -v xray >/dev/null 2>&1 && xray test -config "$XRAY_CONFIG"; then
    green "Xray 配置正常"
  else
    red "Xray 配置异常"
    failed=1
  fi

  echo
  echo "[2] Caddy 配置检查"
  if [[ -f "$CADDYFILE" ]] && command -v caddy >/dev/null 2>&1 && caddy validate --config "$CADDYFILE"; then
    green "Caddy 配置正常"
  else
    red "Caddy 配置异常"
    failed=1
  fi

  echo
  echo "[3] 服务状态"
  if systemctl is-active --quiet xray; then
    green "Xray 运行中"
  else
    red "Xray 未运行"
    failed=1
  fi

  if systemctl is-active --quiet caddy; then
    green "Caddy 运行中"
  else
    red "Caddy 未运行"
    failed=1
  fi

  echo
  echo "[4] 端口监听"
  if ss -lntp | grep -E "(:80|:443|:${REALITY_PORT}|:${XRAY_LOCAL_WS_PORT}|:${XRAY_LOCAL_XHTTP_PORT})\b"; then
    green "端口监听检查完成"
  else
    red "关键端口未完整监听"
    failed=1
  fi

  echo
  echo "[5] 域名解析"
  if [[ -n "$DOMAIN" ]]; then
    check_domain_resolution || failed=1
  else
    yellow "未设置域名，跳过"
  fi

  echo
  echo "[6] 证书状态"
  cert_status || failed=1

  return "$failed"
}

install_health_service() {
  cat > /usr/local/bin/xmg-health <<'EOF'
#!/usr/bin/env bash
exec /usr/local/bin/xmg doctor
EOF
  chmod 0755 /usr/local/bin/xmg-health

  cat > /etc/systemd/system/xmg-health.service <<'EOF'
[Unit]
Description=XMG Health Check
After=network-online.target xray.service caddy.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/xmg-health
EOF

  cat > /etc/systemd/system/xmg-health.timer <<'EOF'
[Unit]
Description=Run XMG Health Check Periodically

[Timer]
OnBootSec=3min
OnUnitActiveSec=30min
Unit=xmg-health.service

[Install]
WantedBy=timers.target
EOF

  systemctl daemon-reload
  systemctl enable --now xmg-health.timer
  green "systemd 健康检查已启用：xmg-health.timer"
}

