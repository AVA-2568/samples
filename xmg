#!/usr/bin/env bash
set -Eeuo pipefail

XMG_VERSION="1.1.0"

BASE_DIR="/etc/xmg"
STATE_FILE="$BASE_DIR/state.env"
USERS_FILE="$BASE_DIR/users.json"

XRAY_CONFIG="/usr/local/etc/xray/config.json"
XRAY_LOCAL_WS_PORT="10001"
XRAY_LOCAL_XHTTP_PORT="10002"

WEB_BASE="/var/www/xmg"
SITE_DIR="$WEB_BASE/site"
PANEL_DIR="$WEB_BASE/panel"
SUB_DIR="$PANEL_DIR/sub"

CADDYFILE="/etc/caddy/Caddyfile"
CADDY_CONF_DIR="/etc/caddy/conf.d"
XMG_CADDYFILE="$CADDY_CONF_DIR/xmg.caddy"
CADDY_CERT_DIR="/var/lib/caddy/.local/share/caddy/certificates"

DEFAULT_REALITY_PORT="8443"
DEFAULT_REALITY_SNI="www.microsoft.com"
DEFAULT_REALITY_DEST="www.microsoft.com:443"

red() { echo -e "\033[31m$*\033[0m"; }
green() { echo -e "\033[32m$*\033[0m"; }
yellow() { echo -e "\033[33m$*\033[0m"; }
blue() { echo -e "\033[34m$*\033[0m"; }

pause() {
  read -rp "按 Enter 返回菜单..."
}

need_root() {
  [[ "${EUID}" -eq 0 ]] || { red "请使用 root 执行：sudo xmg"; exit 1; }
}

detect_os() {
  [[ -f /etc/os-release ]] || { red "无法识别系统，仅支持 Debian / Ubuntu。"; exit 1; }

  # shellcheck disable=SC1091
  . /etc/os-release

  case "${ID:-}" in
    debian|ubuntu) ;;
    *)
      red "当前系统 ${ID:-unknown} 不受支持，仅支持 Debian / Ubuntu。"
      exit 1
      ;;
  esac
}

init_dirs() {
  mkdir -p "$BASE_DIR" "$WEB_BASE" "$SITE_DIR" "$PANEL_DIR" "$SUB_DIR"
  chmod 0700 "$BASE_DIR"
}

random_token() {
  openssl rand -hex 16
}

random_path() {
  echo "/$(openssl rand -hex 10)"
}

gen_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen
  else
    cat /proc/sys/kernel/random/uuid
  fi
}

load_state() {
  if [[ -f "$STATE_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$STATE_FILE"
  fi

  : "${DOMAIN:=}"
  : "${EMAIL:=}"
  : "${PUBLIC_HOST:=}"
  : "${REALITY_PORT:=$DEFAULT_REALITY_PORT}"
  : "${REALITY_SNI:=$DEFAULT_REALITY_SNI}"
  : "${REALITY_DEST:=$DEFAULT_REALITY_DEST}"
  : "${WS_PATH:=$(random_path)}"
  : "${XHTTP_TLS_PATH:=$(random_path)}"
  : "${REALITY_XHTTP_PATH:=$(random_path)}"
  : "${SUB_TOKEN:=$(random_token)}"
  : "${PANEL_USER:=admin}"
  : "${PANEL_PASS:=$(openssl rand -base64 18 | tr -d '=+/')}"
  : "${REALITY_PRIVATE_KEY:=}"
  : "${REALITY_PUBLIC_KEY:=}"
  : "${REALITY_SHORT_ID:=}"
  : "${SITE_REPO:=}"
  : "${SITE_BRANCH:=main}"
}

save_state() {
  umask 077
  cat > "$STATE_FILE" <<EOF
DOMAIN="$DOMAIN"
EMAIL="$EMAIL"
PUBLIC_HOST="$PUBLIC_HOST"
REALITY_PORT="$REALITY_PORT"
REALITY_SNI="$REALITY_SNI"
REALITY_DEST="$REALITY_DEST"
WS_PATH="$WS_PATH"
XHTTP_TLS_PATH="$XHTTP_TLS_PATH"
REALITY_XHTTP_PATH="$REALITY_XHTTP_PATH"
SUB_TOKEN="$SUB_TOKEN"
PANEL_USER="$PANEL_USER"
PANEL_PASS="$PANEL_PASS"
REALITY_PRIVATE_KEY="$REALITY_PRIVATE_KEY"
REALITY_PUBLIC_KEY="$REALITY_PUBLIC_KEY"
REALITY_SHORT_ID="$REALITY_SHORT_ID"
SITE_REPO="$SITE_REPO"
SITE_BRANCH="$SITE_BRANCH"
EOF
  chmod 0600 "$STATE_FILE"
}

ensure_users_file() {
  if [[ ! -f "$USERS_FILE" ]]; then
    local uuid
    uuid="$(gen_uuid)"

    umask 077
    jq -n \
      --arg name "default" \
      --arg uuid "$uuid" \
      '{
        users: [
          {
            name: $name,
            uuid: $uuid,
            enabled: true,
            reality: true,
            ws: true,
            xhttp_tls: true,
            created_at: now | todate
          }
        ]
      }' > "$USERS_FILE"

    chmod 0600 "$USERS_FILE"
  fi
}

require_domain() {
  if [[ -z "$DOMAIN" ]]; then
    red "请先设置域名。"
    return 1
  fi
}

require_xray() {
  if ! command -v xray >/dev/null 2>&1; then
    red "Xray-core 未安装，请先执行安装。"
    return 1
  fi
}

install_base_deps() {
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y \
    curl ca-certificates gnupg lsb-release jq openssl uuid-runtime \
    git unzip tar cron ufw python3 dnsutils iproute2 \
    debian-keyring debian-archive-keyring apt-transport-https
}

install_xray() {
  install_base_deps

  local tmp
  tmp="$(mktemp)"
  curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh -o "$tmp"
  bash "$tmp" install
  rm -f "$tmp"

  systemctl enable xray
  green "Xray-core 安装/更新完成。"
}

install_caddy() {
  install_base_deps

  if ! command -v caddy >/dev/null 2>&1; then
    install -d -m 0755 /etc/apt/keyrings

    if [[ ! -f /etc/apt/keyrings/caddy-stable-archive-keyring.gpg ]]; then
      curl -fsSL "https://dl.cloudsmith.io/public/caddy/stable/gpg.key" \
        | gpg --dearmor -o /etc/apt/keyrings/caddy-stable-archive-keyring.gpg
      chmod 0644 /etc/apt/keyrings/caddy-stable-archive-keyring.gpg
    fi

    curl -fsSL "https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt" \
      -o /etc/apt/sources.list.d/caddy-stable.list
    chmod 0644 /etc/apt/sources.list.d/caddy-stable.list

    apt-get update -y
    apt-get install -y caddy
  fi

  systemctl enable caddy
  green "Caddy 安装/更新完成。"
}

port_in_use_by_allowed_service() {
  local port="$1"
  local allowed="$2"

  ss -lntp 2>/dev/null | grep -E "[:.]${port}\b" | grep -Eq "$allowed"
}

check_port_free_or_owned() {
  local port="$1"
  local name="$2"
  local allowed="$3"

  if ! ss -lntp 2>/dev/null | grep -Eq "[:.]${port}\b"; then
    return 0
  fi

  if port_in_use_by_allowed_service "$port" "$allowed"; then
    yellow "端口 $port 已由预期服务占用：$name"
    return 0
  fi

  red "端口被其他进程占用：$port / $name"
  ss -lntp 2>/dev/null | grep -E "[:.]${port}\b" || true
  return 1
}

preflight_ports() {
  check_port_free_or_owned 80 "Caddy HTTP" "caddy"
  check_port_free_or_owned 443 "Caddy HTTPS" "caddy"
  check_port_free_or_owned "$REALITY_PORT" "Reality-XHTTP" "xray"
  check_port_free_or_owned "$XRAY_LOCAL_WS_PORT" "Xray WS local" "xray"
  check_port_free_or_owned "$XRAY_LOCAL_XHTTP_PORT" "Xray XHTTP local" "xray"
}

get_public_ipv4() {
  curl -fs4 --max-time 5 https://api.ipify.org || true
}

get_public_ipv6() {
  curl -fs6 --max-time 5 https://api64.ipify.org || true
}

check_domain_resolution() {
  require_domain

  local local_v4 local_v6 dns_a dns_aaaa ok
  local_v4="$(get_public_ipv4)"
  local_v6="$(get_public_ipv6)"
  dns_a="$(dig +short A "$DOMAIN" 2>/dev/null || true)"
  dns_aaaa="$(dig +short AAAA "$DOMAIN" 2>/dev/null || true)"
  ok="0"

  if [[ -n "$local_v4" ]] && grep -Fxq "$local_v4" <<< "$dns_a"; then
    ok="1"
  fi

  if [[ -n "$local_v6" ]] && grep -Fxq "$local_v6" <<< "$dns_aaaa"; then
    ok="1"
  fi

  if [[ "$ok" != "1" ]]; then
    red "域名解析未指向本机，Caddy 自动 TLS 可能失败。"
    echo "域名：$DOMAIN"
    echo "本机 IPv4：${local_v4:-无}"
    echo "DNS A：${dns_a:-无}"
    echo "本机 IPv6：${local_v6:-无}"
    echo "DNS AAAA：${dns_aaaa:-无}"
    return 1
  fi

  green "域名解析检查通过：$DOMAIN"
}

gen_reality_keys() {
  require_xray

  if [[ -n "$REALITY_PRIVATE_KEY" && -n "$REALITY_PUBLIC_KEY" && -n "$REALITY_SHORT_ID" ]]; then
    return 0
  fi

  local output
  output="$(xray x25519)"

  REALITY_PRIVATE_KEY="$(awk -F': ' '/Private key/ {print $2}' <<< "$output")"
  REALITY_PUBLIC_KEY="$(awk -F': ' '/Public key/ {print $2}' <<< "$output")"
  REALITY_SHORT_ID="$(openssl rand -hex 8)"

  save_state
}

urlencode_path() {
  local raw="$1"
  python3 - "$raw" <<'PY'
import sys
from urllib.parse import quote
print(quote(sys.argv[1], safe=""))
PY
}

public_host_for_reality() {
  if [[ -n "$PUBLIC_HOST" ]]; then
    echo "$PUBLIC_HOST"
  elif [[ -n "$DOMAIN" ]]; then
    echo "$DOMAIN"
  else
    curl -fs4 --max-time 5 https://api.ipify.org || echo "YOUR_SERVER_IP"
  fi
}

enabled_clients_json() {
  local field="$1"
  jq -c --arg field "$field" '
    [
      .users[]
      | select(.enabled == true)
      | select(.[$field] == true)
      | {
          id: .uuid,
          email: .name,
          level: 0
        }
    ]
  ' "$USERS_FILE"
}

write_xray_config() {
  require_xray
  ensure_users_file
  gen_reality_keys

  local reality_clients ws_clients xhttp_tls_clients tmp backup
  reality_clients="$(enabled_clients_json reality)"
  ws_clients="$(enabled_clients_json ws)"
  xhttp_tls_clients="$(enabled_clients_json xhttp_tls)"
  tmp="$(mktemp)"
  backup="${XRAY_CONFIG}.bak.$(date +%Y%m%d-%H%M%S)"

  mkdir -p "$(dirname "$XRAY_CONFIG")"

  jq -n \
    --argjson reality_port "$REALITY_PORT" \
    --argjson ws_local_port "$XRAY_LOCAL_WS_PORT" \
    --argjson xhttp_local_port "$XRAY_LOCAL_XHTTP_PORT" \
    --arg reality_sni "$REALITY_SNI" \
    --arg reality_dest "$REALITY_DEST" \
    --arg reality_private_key "$REALITY_PRIVATE_KEY" \
    --arg reality_short_id "$REALITY_SHORT_ID" \
    --arg ws_path "$WS_PATH" \
    --arg xhttp_tls_path "$XHTTP_TLS_PATH" \
    --arg reality_xhttp_path "$REALITY_XHTTP_PATH" \
    --argjson reality_clients "$reality_clients" \
    --argjson ws_clients "$ws_clients" \
    --argjson xhttp_tls_clients "$xhttp_tls_clients" \
    '{
      log: {
        loglevel: "warning"
      },
      inbounds: [
        {
          tag: "vless-reality-xhttp",
          listen: "0.0.0.0",
          port: $reality_port,
          protocol: "vless",
          settings: {
            clients: $reality_clients,
            decryption: "none"
          },
          streamSettings: {
            network: "xhttp",
            security: "reality",
            realitySettings: {
              show: false,
              dest: $reality_dest,
              xver: 0,
              serverNames: [$reality_sni],
              privateKey: $reality_private_key,
              shortIds: [$reality_short_id]
            },
            xhttpSettings: {
              path: $reality_xhttp_path,
              mode: "auto"
            },
            sockopt: {
              tcpFastOpen: true
            }
          },
          sniffing: {
            enabled: true,
            destOverride: ["http", "tls", "quic"]
          }
        },
        {
          tag: "vless-ws-caddy",
          listen: "127.0.0.1",
          port: $ws_local_port,
          protocol: "vless",
          settings: {
            clients: $ws_clients,
            decryption: "none"
          },
          streamSettings: {
            network: "ws",
            security: "none",
            wsSettings: {
              path: $ws_path
            },
            sockopt: {
              tcpFastOpen: true
            }
          },
          sniffing: {
            enabled: true,
            destOverride: ["http", "tls"]
          }
        },
        {
          tag: "vless-xhttp-caddy",
          listen: "127.0.0.1",
          port: $xhttp_local_port,
          protocol: "vless",
          settings: {
            clients: $xhttp_tls_clients,
            decryption: "none"
          },
          streamSettings: {
            network: "xhttp",
            security: "none",
            xhttpSettings: {
              path: $xhttp_tls_path,
              mode: "auto"
            },
            sockopt: {
              tcpFastOpen: true
            }
          },
          sniffing: {
            enabled: true,
            destOverride: ["http", "tls"]
          }
        }
      ],
      outbounds: [
        {
          tag: "direct",
          protocol: "freedom"
        },
        {
          tag: "block",
          protocol: "blackhole"
        }
      ],
      routing: {
        domainStrategy: "AsIs",
        rules: [
          {
            type: "field",
            ip: ["geoip:private"],
            outboundTag: "block"
          },
          {
            type: "field",
            protocol: ["bittorrent"],
            outboundTag: "block"
          }
        ]
      },
      policy: {
        levels: {
          "0": {
            handshake: 4,
            connIdle: 300,
            uplinkOnly: 2,
            downlinkOnly: 5
          }
        }
      }
    }' > "$tmp"

  xray test -config "$tmp"

  if [[ -f "$XRAY_CONFIG" ]]; then
    cp "$XRAY_CONFIG" "$backup"
  fi

  install -m 0644 "$tmp" "$XRAY_CONFIG"
  rm -f "$tmp"

  if ! systemctl restart xray; then
    red "Xray 重启失败，尝试回滚配置。"
    if [[ -f "$backup" ]]; then
      cp "$backup" "$XRAY_CONFIG"
      systemctl restart xray || true
    fi
    return 1
  fi

  green "Xray 配置已生成并重启。"
}

install_default_site() {
  mkdir -p "$SITE_DIR"

  if [[ -f "$SITE_DIR/index.html" ]]; then
    return 0
  fi

  cat > "$SITE_DIR/index.html" <<'EOF'
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Welcome</title>
  <style>
    body{font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;margin:0;background:#f6f7fb;color:#202124}
    main{max-width:760px;margin:12vh auto;padding:32px;background:#fff;border-radius:18px;box-shadow:0 12px 40px rgba(0,0,0,.08)}
    h1{margin-top:0}
    p{line-height:1.7;color:#5f6368}
  </style>
</head>
<body>
<main>
  <h1>Welcome</h1>
  <p>This site is running normally.</p>
</main>
</body>
</html>
EOF
}

pull_site_from_github() {
  read -rp "GitHub 静态站仓库地址，例如 https://github.com/user/site.git: " SITE_REPO
  read -rp "分支，默认 main: " input_branch
  SITE_BRANCH="${input_branch:-main}"

  if [[ -z "$SITE_REPO" ]]; then
    red "仓库地址不能为空。"
    return 1
  fi

  rm -rf "$SITE_DIR.tmp"
  git clone --depth 1 -b "$SITE_BRANCH" "$SITE_REPO" "$SITE_DIR.tmp"

  rm -rf "$SITE_DIR"
  mkdir -p "$SITE_DIR"

  if [[ -d "$SITE_DIR.tmp/dist" ]]; then
    cp -a "$SITE_DIR.tmp/dist/." "$SITE_DIR/"
  elif [[ -d "$SITE_DIR.tmp/public" ]]; then
    cp -a "$SITE_DIR.tmp/public/." "$SITE_DIR/"
  else
    cp -a "$SITE_DIR.tmp/." "$SITE_DIR/"
    rm -rf "$SITE_DIR/.git"
  fi

  rm -rf "$SITE_DIR.tmp"
  save_state
  green "伪装站已部署到 $SITE_DIR"
}

ensure_caddy_import() {
  mkdir -p "$CADDY_CONF_DIR"

  if [[ ! -f "$CADDYFILE" ]]; then
    cat > "$CADDYFILE" <<EOF
{
	email ${EMAIL:-admin@example.com}
	servers {
		protocols h1 h2 h3
	}
}

import /etc/caddy/conf.d/*.caddy
EOF
    return 0
  fi

  if ! grep -q 'import /etc/caddy/conf.d/\*.caddy' "$CADDYFILE"; then
    cp "$CADDYFILE" "$CADDYFILE.bak.$(date +%Y%m%d-%H%M%S)"
    cat >> "$CADDYFILE" <<'EOF'

import /etc/caddy/conf.d/*.caddy
EOF
  fi
}

write_caddyfile() {
  require_domain
  check_domain_resolution
  install_default_site
  ensure_caddy_import

  local hashed_pass tmp backup
  hashed_pass="$(caddy hash-password --plaintext "$PANEL_PASS")"
  tmp="$(mktemp)"
  backup="${XMG_CADDYFILE}.bak.$(date +%Y%m%d-%H%M%S)"

  cat > "$tmp" <<EOF
$DOMAIN {
	encode zstd gzip

	@ws path $WS_PATH
	reverse_proxy @ws 127.0.0.1:$XRAY_LOCAL_WS_PORT

	@xhttp path $XHTTP_TLS_PATH*
	reverse_proxy @xhttp 127.0.0.1:$XRAY_LOCAL_XHTTP_PORT

	@panel path /$SUB_TOKEN /$SUB_TOKEN/*
	basic_auth @panel {
		$PANEL_USER $hashed_pass
	}
	handle @panel {
		root * $PANEL_DIR
		file_server
	}

	handle {
		root * $SITE_DIR
		try_files {path} /index.html
		file_server
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
}
EOF

  if [[ -f "$XMG_CADDYFILE" ]]; then
    cp "$XMG_CADDYFILE" "$backup"
  fi

  install -m 0644 "$tmp" "$XMG_CADDYFILE"
  rm -f "$tmp"

  if ! caddy validate --config "$CADDYFILE"; then
    red "Caddy 配置校验失败，尝试回滚。"
    if [[ -f "$backup" ]]; then
      cp "$backup" "$XMG_CADDYFILE"
    fi
    return 1
  fi

  if ! systemctl reload caddy; then
    systemctl restart caddy
  fi

  green "Caddy 分层配置已生成：$XMG_CADDYFILE"
}

setup_firewall() {
  if ! command -v ufw >/dev/null 2>&1; then
    apt-get install -y ufw
  fi

  yellow "即将放行 80/tcp、443/tcp、Reality 端口 $REALITY_PORT/tcp。"
  yellow "如你的 SSH 不是 22 端口，请先确保已手动放行。"

  ufw allow 22/tcp || true
  ufw allow 80/tcp || true
  ufw allow 443/tcp || true
  ufw allow "$REALITY_PORT/tcp" || true
  ufw --force enable || true

  green "防火墙规则已应用。"
}

set_basic_info() {
  read -rp "域名，必须已解析到本机，例如 example.com: " DOMAIN
  read -rp "ACME 邮箱，例如 admin@example.com: " EMAIL
  read -rp "Reality 连接地址，留空默认使用域名或公网 IP: " PUBLIC_HOST

  read -rp "Reality 端口，默认 $REALITY_PORT: " input_reality_port
  REALITY_PORT="${input_reality_port:-$REALITY_PORT}"

  read -rp "Reality SNI，默认 $REALITY_SNI: " input_reality_sni
  REALITY_SNI="${input_reality_sni:-$REALITY_SNI}"
  REALITY_DEST="${REALITY_SNI}:443"

  echo "WS 随机路径：$WS_PATH"
  read -rp "WS 路径，回车保持当前值: " input_ws_path
  WS_PATH="${input_ws_path:-$WS_PATH}"

  echo "XHTTP-TLS 随机路径：$XHTTP_TLS_PATH"
  read -rp "XHTTP-TLS 路径，回车保持当前值: " input_xhttp_tls_path
  XHTTP_TLS_PATH="${input_xhttp_tls_path:-$XHTTP_TLS_PATH}"

  echo "Reality-XHTTP 随机路径：$REALITY_XHTTP_PATH"
  read -rp "Reality-XHTTP 路径，回车保持当前值: " input_reality_xhttp_path
  REALITY_XHTTP_PATH="${input_reality_xhttp_path:-$REALITY_XHTTP_PATH}"

  if [[ "$WS_PATH" != /* || "$XHTTP_TLS_PATH" != /* || "$REALITY_XHTTP_PATH" != /* ]]; then
    red "路径必须以 / 开头。"
    return 1
  fi

  save_state
  green "基础信息已保存。"
}

add_user() {
  ensure_users_file

  local name uuid reality ws xhttp_tls tmp
  read -rp "用户名称，例如 alice: " name

  if [[ -z "$name" ]]; then
    red "用户名称不能为空。"
    return 1
  fi

  if jq -e --arg name "$name" '.users[] | select(.name == $name)' "$USERS_FILE" >/dev/null; then
    red "用户已存在。"
    return 1
  fi

  uuid="$(gen_uuid)"

  read -rp "启用 Reality-XHTTP? [Y/n]: " reality
  read -rp "启用 WS-TLS? [Y/n]: " ws
  read -rp "启用 XHTTP-TLS? [Y/n]: " xhttp_tls

  reality="$([[ "${reality,,}" == "n" ]] && echo false || echo true)"
  ws="$([[ "${ws,,}" == "n" ]] && echo false || echo true)"
  xhttp_tls="$([[ "${xhttp_tls,,}" == "n" ]] && echo false || echo true)"

  tmp="$(mktemp)"
  jq \
    --arg name "$name" \
    --arg uuid "$uuid" \
    --argjson reality "$reality" \
    --argjson ws "$ws" \
    --argjson xhttp_tls "$xhttp_tls" \
    '.users += [{
      name: $name,
      uuid: $uuid,
      enabled: true,
      reality: $reality,
      ws: $ws,
      xhttp_tls: $xhttp_tls,
      created_at: now | todate
    }]' "$USERS_FILE" > "$tmp"

  mv "$tmp" "$USERS_FILE"
  chmod 0600 "$USERS_FILE"

  write_xray_config
  build_subscriptions
  green "用户已添加：$name / $uuid"
}

delete_user() {
  ensure_users_file
  jq -r '.users[] | "\(.name)\t\(.uuid)\tenabled=\(.enabled)"' "$USERS_FILE"

  local name tmp
  read -rp "请输入要删除的用户名称: " name

  if [[ -z "$name" ]]; then
    red "用户名称不能为空。"
    return 1
  fi

  tmp="$(mktemp)"
  jq --arg name "$name" '.users = [.users[] | select(.name != $name)]' "$USERS_FILE" > "$tmp"
  mv "$tmp" "$USERS_FILE"
  chmod 0600 "$USERS_FILE"

  write_xray_config
  build_subscriptions
  green "用户已删除：$name"
}

toggle_user() {
  ensure_users_file
  jq -r '.users[] | "\(.name)\t\(.uuid)\tenabled=\(.enabled)"' "$USERS_FILE"

  local name tmp
  read -rp "请输入用户名称: " name

  tmp="$(mktemp)"
  jq --arg name "$name" '
    .users = [
      .users[]
      | if .name == $name then .enabled = (.enabled | not) else . end
    ]
  ' "$USERS_FILE" > "$tmp"

  mv "$tmp" "$USERS_FILE"
  chmod 0600 "$USERS_FILE"

  write_xray_config
  build_subscriptions
  green "用户状态已切换。"
}

list_users() {
