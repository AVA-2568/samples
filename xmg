uninstall_xmg() {
  yellow "此操作会卸载 XMG 配置，可选择是否卸载 Xray/Caddy。"
  read -rp "确认继续？输入 YES: " confirm
  [[ "$confirm" == "YES" ]] || return 0

  backup_config || true

  systemctl disable --now xmg-health.timer 2>/dev/null || true
  rm -f /etc/systemd/system/xmg-health.service /etc/systemd/system/xmg-health.timer /usr/local/bin/xmg-health
  systemctl daemon-reload || true

  systemctl stop xray caddy 2>/dev/null || true

  read -rp "是否删除 Xray-core？[y/N]: " remove_xray
  if [[ "${remove_xray,,}" == "y" ]]; then
    local tmp
    tmp="$(mktemp)"
    curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh -o "$tmp"
    bash "$tmp" remove --purge || true
    rm -f "$tmp"
  fi

  read -rp "是否删除 Caddy？[y/N]: " remove_caddy
  if [[ "${remove_caddy,,}" == "y" ]]; then
    apt-get purge -y caddy || true
  fi

  rm -rf "$BASE_DIR" "$WEB_BASE"
  rm -f "$XMG_CADDYFILE"
  rm -f /usr/local/bin/xmg

  green "卸载完成。"
}

